# Get this from your Neon project dashboard: Connection Details -> Connection string
# It looks like: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/retrodex?sslmode=require

# Comma-separated list of origins allowed to call this API (your frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
GROQ_API_KEY=your_groq_api_key_here